  "repository": {
    "type": "git",
    "url": "https://github.com/occar421/unifiedjs-gherkin.git",
    "directory": "packages/remark-gherkin"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
